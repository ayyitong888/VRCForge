{
  "schema": "vrcforge.skill-package.workflow.v1",
  "mode": "read_only",
  "steps": [
    {
      "name": "build_optimizer_report",
      "tool": "vrcforge_optimization_plan",
      "writes": false
    }
  ],
  "output": {
    "format": "optimizer-decision-report",
    "sections": [
      "Summary",
      "Highest-impact findings",
      "PC/Quest differences",
      "Recommended order",
      "Approval-required follow-ups"
    ]
  },
  "approval": {
    "required": false,
    "reason": "The single tool call and report formatting are read-only."
  },
  "rollback": {
    "required": false,
    "reason": "The workflow does not mutate local state or Unity assets."
  }
}
